{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deckhand",
  "version": "0.1.0",
  "identifier": "dev.deckhand.app",
  "build": {
    "beforeDevCommand": "vite --port 1420 --strictPort",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run --cwd ../.. build:sidecar && bun run --cwd .. build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/deckhand-sidecar"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
